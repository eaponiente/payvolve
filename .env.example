# Copy to .env and fill in real values. Do NOT commit .env.
# Generate secrets with: openssl rand -base64 32

# PostgreSQL connection string (local dev runs on port 5433).
DATABASE_URL="postgresql://user:password@localhost:5433/pondoflow?schema=public"

# Auth.js JWT signing key. MUST be a unique, high-entropy value in production
# (rotating it invalidates all existing sessions).
AUTH_SECRET=""

# Required for Auth.js behind a proxy / on Vercel.
AUTH_TRUST_HOST="true"

# Base64 32-byte key for encrypting employee government IDs at rest (RA 10173).
# Losing it makes existing encrypted IDs unrecoverable — keep it safe.
FIELD_ENCRYPTION_KEY=""

# Comma-separated emails allowed to view the /dev operator tools (platform
# operators, not tenant users).
DEV_EMAILS=""
