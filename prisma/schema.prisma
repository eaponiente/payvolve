generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  EMPLOYEE
}

enum PayType {
  MONTHLY
  DAILY
  HOURLY
}

enum TimeEntrySource {
  CLOCK
  MANUAL
}

enum PayrollRunStatus {
  DRAFT
  FINALIZED
}

enum PayrollRunType {
  REGULAR
  THIRTEENTH_MONTH
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum InvoiceStatus {
  OPEN
  PAID
  VOID
}

model Company {
  id              String   @id @default(cuid())
  name            String
  // payroll settings
  workHoursPerDay Int      @default(8)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users        User[]
  employees    Employee[]
  payrollRuns  PayrollRun[]
  shifts       Shift[]
  subscription Subscription?
  invoices     Invoice[]
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(EMPLOYEE)
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee     Employee?
  // Bumped to invalidate all previously-issued JWTs for this user (e.g. on
  // role change or forced logout). Checked in the auth.ts jwt callback.
  tokenVersion Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId])
}

model Employee {
  id               String   @id @default(cuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId           String?  @unique
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstName        String
  lastName         String
  position         String   @default("")
  hireDate         DateTime
  active           Boolean  @default(true)
  payType          PayType
  // base rate in PHP: monthly salary for MONTHLY, daily rate for DAILY, hourly rate for HOURLY
  baseRate         Decimal  @db.Decimal(12, 2)
  tin              String   @default("")
  sssNumber        String   @default("")
  philhealthNumber String   @default("")
  pagibigNumber    String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  timeEntries TimeEntry[]
  payslips    Payslip[]
  shifts      Shift[]

  @@index([companyId])
}

// NOTE: a partial unique index enforces at most one OPEN entry (clockOut IS
// NULL) per employee, guarding against a clock-in race condition. Prisma's
// schema DSL can't express partial indexes, so it's hand-written raw SQL in
// migration 20260705103532_time_entry_open_unique — not represented here.
// Don't let `prisma migrate dev`/`db push` schema-drift-reset it away.
model TimeEntry {
  id         String          @id @default(cuid())
  employeeId String
  employee   Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clockIn    DateTime
  clockOut   DateTime?
  source     TimeEntrySource @default(CLOCK)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([employeeId, clockIn])
}

model PayrollRun {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        PayrollRunType   @default(REGULAR)
  periodStart DateTime
  periodEnd   DateTime
  payoutDate  DateTime
  status      PayrollRunStatus @default(DRAFT)
  finalizedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  payslips Payslip[]

  @@index([companyId, periodStart])
}

model Payslip {
  id              String     @id @default(cuid())
  payrollRunId    String
  payrollRun      PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  // JSON breakdown: { earnings: [{label, detail?, amount}], deductions: [{label, amount}] }
  breakdown       Json
  gross           Decimal    @db.Decimal(12, 2)
  totalDeductions Decimal    @db.Decimal(12, 2)
  net             Decimal    @db.Decimal(12, 2)
  createdAt       DateTime   @default(now())

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
}

model Shift {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startsAt   DateTime
  endsAt     DateTime
  role       String   @default("")
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId, startsAt])
  @@index([employeeId, startsAt])
}

model Subscription {
  id                 String             @id @default(cuid())
  companyId          String             @unique
  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status             SubscriptionStatus @default(TRIALING)
  includeEwa         Boolean            @default(false)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  // stubbed payment-provider references (swap for real PayMongo/Stripe IDs later)
  providerCustomerId String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

// In-app bug reports. Cross-tenant; visible only to platform devs.
model BugReport {
  id            String   @id @default(cuid())
  name          String
  feedback      String
  reporterEmail String   @default("")
  companyId     String?
  createdAt     DateTime @default(now())
}

// Public "Contact us" submissions from the marketing site (no tenant).
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String   @default("")
  message   String
  createdAt DateTime @default(now())
}

model Invoice {
  id               String        @id @default(cuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  periodStart      DateTime
  periodEnd        DateTime
  employeeCount    Int
  baseAmount       Decimal       @db.Decimal(12, 2)
  perEmployeeTotal Decimal       @db.Decimal(12, 2)
  ewaTotal         Decimal       @db.Decimal(12, 2)
  total            Decimal       @db.Decimal(12, 2)
  status           InvoiceStatus @default(OPEN)
  paidAt           DateTime?
  createdAt        DateTime      @default(now())

  @@index([companyId, periodStart])
}
